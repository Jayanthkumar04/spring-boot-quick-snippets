public List<Order> getOrderDetailsOnSearch(FilterRequest filterReq) {

    // 1. If no filter → return all
    if (filterReq == null) {
        return orderRepo.findAll();
    }

    // 2. Apply specification
    return orderRepo.findAll(OrderSpecification.filterOrders(filterReq));
}
