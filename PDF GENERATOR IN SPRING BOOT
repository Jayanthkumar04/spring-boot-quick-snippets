private String getBase64Image() throws Exception {
    InputStream is = getClass()
        .getClassLoader()
        .getResourceAsStream("templates/logo.png");

    byte[] bytes = is.readAllBytes();

    return Base64.getEncoder().encodeToString(bytes);
}
